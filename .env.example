# ─── Database ───
DATABASE_URL=postgresql://user:password@localhost:5432/voom_ghana
# SUPABASE_DATABASE_URL=   # Alternative: Supabase PostgreSQL (auto-enables SSL)

# ─── Authentication ───
JWT_SECRET=your-jwt-secret-here
VITE_APP_ID=voom-ghana
OAUTH_SERVER_URL=https://your-oauth-server.com
OWNER_OPEN_ID=                # OpenID of the auto-admin user

# ─── Google OAuth ───
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Paystack (FUTURE — not needed for catalog-first launch) ───
# PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxx
# VITE_PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxx

# ─── Cloudinary (Image Uploads) ───
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── Forge API (Fallback Storage) ───
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=

# ─── Twilio (WhatsApp OTP) ───
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=

# ─── Server ───
PORT=3000
NODE_ENV=development
